# Copy this file to .env (rename to .env), paste your anon key on the line below, save, then: npm run sup
# Supabase → Project Settings → API → anon public (long string starting with eyJ)

SUPABASE_ANON_KEY=

# Optional — defaults to https://wxcuipdfrohozowdhlql.supabase.co
# SUPABASE_URL=https://wxcuipdfrohozowdhlql.supabase.co

# Optional — if set without SUPABASE_URL, builds URL as https://<ref>.supabase.co
# SUPABASE_PROJECT_REF=wxcuipdfrohozowdhlql
